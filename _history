{"entries":[{"timestamp":1781865043899,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":1514,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":442,"diffs":[[1,"\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":233,"length1":41,"diffs":[[1,"        \"README.md\"\n"]]},{"start1":260,"length1":35,"diffs":[[1,"    \"additionalFilePaths\": []\n"]]}]},{"type":"added","filename":"custom.ts","value":"enum ResetType {\n    //% block=\"Full\"\n    Full,\n    //% block=\"Partial\"\n    Partial\n}\n\n//% color=\"#E67E22\" weight=100 icon=\"\\uf1ec\" block=\"Custom Actions\"\nnamespace customCalculations {\n    let partialResetHandler: () => void = null;\n\n    /**\n     * Registers code to run when a Partial reset is triggered.\n     * Use this instead of or alongside the standard 'on start'.\n     */\n    //% block=\"on partial start\"\n    //% weight=95\n    export function onPartialStart(handler: () => void) {\n        partialResetHandler = handler;\n        // מריץ את הקוד פעם ראשונה בהפעלת הלוח, בדיוק כמו on start\n        control.runInParallel(handler);\n    }\n\n    /**\n     * Resets the Micro:bit (Full) or re-runs the partial start code without clearing variables (Partial).\n     * @param mode choose between Full or Partial reset, eg: ResetType.Full\n     */\n    //% block=\"restart || %mode\"\n    //% mode.defl=ResetType.Full\n    //% expandableArgumentMode=\"toggle\"\n    //% weight=90\n    export function resetMicrobit(mode?: ResetType): void {\n        let chosenMode = (mode === undefined) ? ResetType.Full : mode;\n\n        if (chosenMode === ResetType.Full) {\n            control.reset(); // אתחול חומרה מלא - מוחק הכל\n        } else {\n            // אתחול חלקי - מריץ מחדש את הקוד הרשום מבלי לאפס משתנים\n            if (partialResetHandler != null) {\n                control.runInParallel(partialResetHandler);\n            }\n        }\n    }\n\n    /**\n     * Divides a number into equal parts and returns the size of each part.\n     * @param total the total number, eg: 100\n     * @param parts the number of parts, eg: 4\n     */\n    //% block=\"divide $total into... $parts equal parts\"\n    //% total.defl=100\n    //% parts.defl=4\n    //% weight=80\n    export function divideIntoParts(total: number, parts: number): number {\n        if (parts === 0) {\n            return 0;\n        }\n        return total / parts;\n    }\n\n    /**\n     * Divides a number into equal parts of a specific size, and returns the number of parts.\n     * @param total the total number, eg: 100\n     * @param size the size of each part, eg: 25\n     */\n    //% block=\"divide $total into equal parts, each part = $size\"\n    //% total.defl=100\n    //% size.defl=25\n    //% weight=70\n    export function divideBySize(total: number, size: number): number {\n        if (size === 0) {\n            return 0;\n        }\n        return total / size;\n    }\n}\n"}]},{"timestamp":1781865604473,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":132,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"54_9+9n)UqUEh.Um1?H,\">a</variable></variables><block type=\"pxt-on-start\" x=\"53\" y=\"49\"><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # # \n        # # # # # \n        # # # # # \n        # # # # # \n        # # # # #\n        `</field><next><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        . . . . . \n        . . . . . \n        . . . . . \n        . . . . . \n        . . . . .\n        `</field><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">Hello!</field></shadow><block ty